    'cpp':        {'.cpp','.cc','.cxx','.hpp','.hxx'},
    'python':     {'.py','.pyw'},
    'javascript': {'.js','.jsx','.mjs'},
    'typescript': {'.ts','.tsx'},
    'java':       {'.java'},
    'kotlin':     {'.kt','.kts'},
    'swift':      {'.swift'},
    'go':         {'.go'},
    'rust':       {'.rs'},
    'ruby':       {'.rb','.rake'},
    'php':        {'.php','.php3','.php4','.php5'},
    'lua':        {'.lua'},
    'dart':       {'.dart'},
    'r':          {'.r','.R','.Rmd'},
    'julia':      {'.jl'},
    'zig':        {'.zig'},
    'crystal':    {'.cr'},
    'nim':        {'.nim','.nims','.nimble'},
    'v':          {'.v','.vv'},
    'perl':       {'.pl','.pm','.pl6'},
    'ocaml':      {'.ml','.mli'},
    'fsharp':     {'.fs','.fsx','.fsi'},
    'scala':      {'.scala','.sc'},
    'haskell':    {'.hs','.lhs'},
    'elixir':     {'.ex','.exs','.heex'},
    'clojure':    {'.clj','.cljs','.cljc'},
    'erlang':     {'.erl','.hrl'},
    'csharp':     {'.cs','.csx'},
    'groovy':     {'.groovy','.gradle','.gvy'},
    'powershell': {'.ps1','.psm1','.psd1'},
    'html':       {'.html','.htm'},
